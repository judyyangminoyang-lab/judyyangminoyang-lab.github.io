rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Helper Functions ---

    // Checks if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the user is authenticated and has a verified email address
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Check if user is the designated Super Administrator (judyyang.minoyang@gmail.com)
    function isSuperAdmin() {
      return isEmailVerified() && request.auth.token.email == "judyyang.minoyang@gmail.com";
    }

    // Checks if the current authenticated user's email is registered in staff_members
    function isStaffMember() {
      return isEmailVerified() && exists(/databases/$(database)/documents/staff_members/$(request.auth.token.email));
    }

    // Evaluates if the operator is authorized for dynamic operations management (SuperAdmin or registered Staff)
    function isAuthorizedStaff() {
      return isSuperAdmin() || isStaffMember();
    }

    // Checks if the current authenticated user's email is registered in staff_members as an admin
    function isStaffAdmin() {
      return isEmailVerified() && 
        exists(/databases/$(database)/documents/staff_members/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/staff_members/$(request.auth.token.email)).data.role == "admin";
    }

    // Checks if the operator is an administrator (either the designated SuperAdmin or a co-admin)
    function isAuthorizedAdmin() {
      return isSuperAdmin() || isStaffAdmin();
    }

    // Validates string ID constraints to guard against resource poisoning
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@]+$');
    }

    // --- Rules for Config State Document ---
    
    match /config/gymState {
      // Allow unrestricted reads and writes so both front-end clients, guests, and the unauthenticated backend server can update the live gym occupancy state seamlessly.
      allow read, write: if true;
    }

    // --- Rules for Staff Directory ---
    
    match /staff_members/{email} {
      // Allow unrestricted reads and writes so that both the backend server and logged-in administrators can query and alter staff members registry on demand.
      allow read, write: if true;
    }

  }
}
